# Database URL — set to a PostgreSQL connection string for production.
# Defaults to local SQLite when not set.
# DATABASE_URL=postgresql://user:password@host:5432/legalease

BYTEZ_API_KEY=your_api_key_here
FRONTEND_URL=http://localhost:5173
JWT_SECRET_KEY=gssoc26_super_secure_secret_key_change_me_in_production

# Document Encryption Key — required in production for cryptographic key separation
# This key encrypts stored contract content (summaries, clause analysis, chat messages)
# at rest using Fernet symmetric encryption. It MUST be different from JWT_SECRET_KEY
# to ensure proper key separation. If JWT_SECRET_KEY is compromised, attackers should
# not be able to decrypt encrypted documents.
#
# In non-production environments (development, testing, local), this falls back to
# JWT_SECRET_KEY if not set for convenience. In production, this is mandatory and
# the application will fail to start without it.
#
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DOCUMENT_ENCRYPTION_KEY=your_dedicated_encryption_key_change_me_in_production

# Refresh Token Configuration
# Refresh tokens are long-lived JWTs stored in HttpOnly cookies for session restoration
# REFRESH_TOKEN_EXPIRE_DAYS=7
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# REFRESH_TOKEN_ROTATION_ENABLED=true

ALLOW_DEV=true
STUB_MODE=true

# Redis URL for distributed rate limiting across multiple workers
# When set, rate limiting state is shared across all application workers
# When not set, rate limiting falls back to process-local in-memory storage
# Format: redis://localhost:6379/0 or rediss://localhost:6379/0 for TLS
# REDIS_URL=redis://localhost:6379/0

# Authentication Rate Limiting Configuration
# Login rate limiting (prevents brute-force attacks)
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_PERIOD=60
AUTH_LOGIN_FAILED_ATTEMPT_LIMIT=10
AUTH_LOGIN_FAILED_ATTEMPT_PERIOD=300
AUTH_LOGIN_LOCKOUT_DURATION=900

# Signup rate limiting (prevents automated signup abuse)
AUTH_SIGNUP_RATE_LIMIT=3
AUTH_SIGNUP_RATE_PERIOD=3600

# Verification resend rate limiting (prevents email spam)
AUTH_VERIFICATION_RATE_LIMIT=3
AUTH_VERIFICATION_RATE_PERIOD=3600

# Global rate limiting configuration
RATE_LIMIT_PERIOD=60
RATE_LIMIT_KEY_CALLS=300
RATE_LIMIT_IP_CALLS=60

# Environment configuration
# Set to "development", "testing", "staging", or "production"
# Defaults to "production" for safety
# Test-specific behaviors are only enabled in non-production environments
ENVIRONMENT=development

# Test mode configuration
# Set to "true" or "1" to enable test-specific behavior in development/testing environments only
# This allows controlled failure simulation for testing authentication workflows
# WARNING: Test mode is automatically disabled in production regardless of this setting
TEST_MODE=false

# AI Model input limits
MAX_SIMPLIFY_INPUT_CHARS=10000


