# Database URL — set to a PostgreSQL connection string for production.
# Defaults to local SQLite (sqlite:///./legalease.db) when not set.
# DATABASE_URL=postgresql://user:password@host:5432/legalease

# Bytez API key - replace with a real key in your local .env (DO NOT commit)
BYTEZ_API_KEY=your_bytez_api_key_here

# Frontend dev URL used for CORS (default used in backend)
FRONTEND_URL=http://localhost:5173

# Secret key used for signing JWT authentication tokens
JWT_SECRET_KEY=gssoc26_super_secure_secret_key_change_me_in_production

# Allow developer mode API key authentication
ALLOW_DEV=true

# Stub mode for offline local development fallback response generation
STUB_MODE=true

# AI Model input limits
MAX_SIMPLIFY_INPUT_CHARS=10000

# Redis URL for distributed rate limiting across multiple workers
# When set, rate limiting state is shared across all application workers
# When not set, rate limiting falls back to process-local in-memory storage
# Format: redis://localhost:6379/0 or rediss://localhost:6379/0 for TLS
# REDIS_URL=redis://localhost:6379/0

# Global rate limiting configuration
RATE_LIMIT_PERIOD=60
RATE_LIMIT_KEY_CALLS=300
RATE_LIMIT_IP_CALLS=60

